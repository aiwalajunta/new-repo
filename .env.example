# =============================================================
# Aditya Textile — Environment Variables
# =============================================================
# Copy this to .env.local for local development.
# On Vercel, set these under Project Settings > Environment Variables.
#
# REQUIRED (app won't boot without these)
# =============================================================

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=generate-a-random-32-char-string-here

# Your Vercel deployment URL (set automatically by Vercel, or set manually)
# NEXTAUTH_URL=https://your-project.vercel.app

# =============================================================
# OPTIONAL — Google Sheets database
# Leave blank to run in mock/demo mode with sample products.
# Add these once your Google Sheet is ready.
# =============================================================

# From your Google Cloud service account JSON
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SPREADSHEET_ID=
# Paste the private key with literal \n (not real newlines) on Vercel
GOOGLE_PRIVATE_KEY=

# =============================================================
# OPTIONAL — Cloudinary (product images)
# =============================================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# =============================================================
# OPTIONAL — Web Push notifications
# =============================================================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@adityatextile.com

# =============================================================
# OPTIONAL — Email (Resend)
# =============================================================
RESEND_API_KEY=
